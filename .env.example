# ============================================
# AdGenius AI - Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# ---- APP ----
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=AdGenius AI

# ---- SUPABASE ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---- GOOGLE AI (Gemini) ----
GOOGLE_AI_API_KEY=your-google-ai-api-key

# ---- LEMON SQUEEZY ----
LEMON_SQUEEZY_STORE_ID=your-store-id
LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-secret
LEMON_SQUEEZY_PRO_MONTHLY_VARIANT_ID=pro-monthly-variant-id
LEMON_SQUEEZY_PRO_YEARLY_VARIANT_ID=pro-yearly-variant-id
LEMON_SQUEEZY_UNLIMITED_MONTHLY_VARIANT_ID=unlimited-monthly-variant-id
LEMON_SQUEEZY_UNLIMITED_YEARLY_VARIANT_ID=unlimited-yearly-variant-id

# ---- PAYPAL ----
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
# Optional: defaults to sandbox. Use https://api-m.paypal.com for live
# PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# ---- EMAIL (Resend) ----
RESEND_API_KEY=re-your-resend-api-key